# 后端环境变量示例（请复制为 .env 并填写真实值）
#
# 复制命令：
#   cd PolyStudio/backend
#   cp env.example .env

# LLM 提供商配置
# 支持的提供商: volcano（火山引擎，默认）、siliconflow（SiliconFlow）
LLM_PROVIDER=volcano

# SiliconFlow LLM 配置（当 LLM_PROVIDER=siliconflow 时使用）
OPENAI_API_KEY=YOUR_API_KEY_HERE
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
MODEL_NAME=deepseek-ai/DeepSeek-V3.1-Terminus

# 图像生成/编辑模型（SiliconFlow images 接口使用）
IMAGE_MODEL_NAME=Qwen/Qwen-Image
EDIT_IMAGE_MODEL_NAME=Qwen/Qwen-Image-Edit-2509

# 用于将本地 /storage/... 拼成可访问的完整 URL（edit_image 需要）
BASE_URL=http://localhost:8000

# LangGraph 多步推理递归上限
RECURSION_LIMIT=200

# 火山引擎配置（图片生成 + LLM）
VOLCANO_API_KEY=YOUR_VOLCANO_API_KEY_HERE
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 火山引擎图片生成模型
VOLCANO_IMAGE_MODEL=seedream-4.5
VOLCANO_EDIT_MODEL=seedream-4.5
# 火山引擎视频生成模型（使用 Seedance 1.5 Pro，支持文生视频、图生视频-首帧、首尾帧）
VOLCANO_VIDEO_MODEL=doubao-seedance-1-5-pro
# 火山引擎 LLM 模型（当 LLM_PROVIDER=volcano 时使用）
VOLCANO_MODEL_NAME=doubao-seed-1-6-251015
# 是否启用 thinking 功能（深度思考能力）：true 或 false
VOLCANO_THINKING_ENABLED=false

# 腾讯云混元生3D API 配置 https://console.cloud.tencent.com/ai3d/packages
TENCENT_AI3D_API_KEY=YOUR_TENCENT_AI3D_API_KEY_HERE
TENCENT_AI3D_BASE_URL=https://api.ai3d.cloud.tencent.com

# 阿里云百炼 Qwen-TTS 配置 🆕
# 获取API Key: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE
# 国内版（北京）: https://dashscope.aliyuncs.com
# 国际版（新加坡）: https://dashscope-intl.aliyuncs.com
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# 人脸检测配置
# 检测方法: opencv（轻量级，使用OpenCV Haar Cascade）或 llm（大模型，使用火山引擎多模态模型）
FACE_DETECTION_METHOD=opencv

# ComfyUI 虚拟人生成配置
# ComfyUI 服务器地址（支持域名或完整URL，如：http://127.0.0.1:8818）
COMFYUI_SERVER_ADDRESS=
# ComfyUI 工作流JSON文件路径（可选，也可以通过工具参数传入）
# 例如：/storage/workflow/infinitetalk_workflow.json
COMFYUI_WORKFLOW_PATH=

# 日志配置
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Mock 模式（用于调试 agent，不调用真实 API）
# 设置为 true 时，图片生成、视频生成和3D生成将返回固定的 mock 数据
# ⚠️ 注意：启用 MOCK_MODE=true 时，必须配置 MOCK_IMAGE_PATH、MOCK_VIDEO_PATH 和 MOCK_MODEL_PATH
MOCK_MODE=false
# Mock 图片路径（启用 MOCK_MODE 时必须配置，必须是 /storage/images/ 下的文件路径）
# 例如：/storage/images/your_mock_image.png
MOCK_IMAGE_PATH=
# Mock 3D模型路径（启用 MOCK_MODE 时必须配置，必须是 /storage/models/ 下的模型目录路径）
# 例如：/storage/models/your_model_dir
MOCK_MODEL_PATH=
# Mock 视频路径（启用 MOCK_MODE 时必须配置，必须是 /storage/videos/ 下的文件路径）
# 例如：/storage/videos/your_mock_video.mp4
MOCK_VIDEO_PATH=